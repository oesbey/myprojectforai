<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Lummy Admin Paneli</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f4f6f9; }
        .sidebar { background: #111827; min-height: 100vh; color: white; padding-top: 20px;}
        .sidebar a { color: #9ca3af; text-decoration: none; padding: 15px 20px; display: block; font-weight: 500; transition: 0.3s;}
        .sidebar a:hover, .sidebar a.active { background: #1f2937; color: #fff; border-left: 4px solid #00E5FF; }
        .card { border: none; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    </style>
</head>
<body>

<div class="d-flex">
    <!-- SOL MENÜ -->
    <div class="sidebar" style="width: 250px;">
        <h4 class="text-center fw-bold mb-4 text-white">LUMMY <span style="color:#00E5FF;">PANEL</span></h4>
        <div class="text-center mb-4">
            <img src="<%= admin.avatar_url %>" class="rounded-circle mb-2" width="60" height="60" style="border: 2px solid #00E5FF; object-fit:cover;">
            <div><b><%= admin.username %></b></div>
            <span class="badge bg-danger mt-1"><i class="fa-solid fa-crown"></i> <%= admin.role %></span>
        </div>
        <a href="/admin/dashboard" class="active"><i class="fa-solid fa-chart-pie me-2"></i> Gösterge Paneli</a>
        <a href="#"><i class="fa-solid fa-users me-2"></i> Kullanıcı Yönetimi</a>
        <a href="#"><i class="fa-solid fa-microphone me-2"></i> Canlı Odalar</a>
        <a href="#"><i class="fa-solid fa-coins me-2"></i> Finans</a>
        <a href="/admin/logout" class="text-danger mt-5"><i class="fa-solid fa-right-from-bracket me-2"></i> Çıkış Yap</a>
    </div>

    <!-- SAĞ İÇERİK -->
    <div class="flex-grow-1 p-4">
        <h3 class="fw-bold mb-4">Sisteme Genel Bakış</h3>
        
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card bg-primary text-white p-4">
                    <h5><i class="fa-solid fa-user-group"></i> Toplam Kullanıcı</h5>
                    <h2><%= toplamUser %></h2>
                </div>
            </div>
        </div>

        <!-- KULLANICI TABLOSU -->
        <div class="card p-4">
            <h5 class="fw-bold mb-3"><i class="fa-solid fa-list"></i> Kayıtlı Kullanıcılar</h5>
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Lummy ID</th>
                        <th>Kullanıcı Adı</th>
                        <th>Seviye</th>
                        <th>Cüzdan</th>
                        <th>Yetki</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    <% usersList.forEach(function(u) { %>
                    <tr>
                        <td><strong><%= u.lummy_id %></strong></td>
                        <td>
                            <img src="<%= u.avatar_url %>" width="30" height="30" class="rounded-circle me-2" style="object-fit:cover;">
                            <%= u.username %>
                        </td>
                        <td><span class="badge bg-info text-dark">Lv.<%= u.level %></span></td>
                        <td><span class="badge bg-warning text-dark"><i class="fa-solid fa-coins"></i> <%= u.coin_balance %></span></td>
                        <td>
                            <% if(u.role === 'superadmin') { %> <span class="badge bg-danger"><i class="fa-solid fa-user-shield"></i> Süper Admin</span>
                            <% } else if(u.role === 'admin') { %> <span class="badge bg-primary">Admin</span>
                            <% } else { %> <span class="badge bg-secondary">Üye</span> <% } %>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal<%= u.id %>">
                                <i class="fa-solid fa-pen"></i> Düzenle
                            </button>
                            <form action="/admin/user/delete" method="POST" class="d-inline" onsubmit="return confirm('Silmek istediğinize emin misiniz?');">
                                <input type="hidden" name="id" value="<%= u.id %>">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ELI5: MODALLAR (AÇILIR PENCERELER) TABLONUN DIŞINA, EN ALTA TAŞINDI! ARTIK EKRAN KİLİTLENMEYECEK -->
<% usersList.forEach(function(u) { %>
<div class="modal fade" id="editModal<%= u.id %>" tabindex="-1">
    <div class="modal-dialog">
        <form action="/admin/user/edit" method="POST" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa-solid fa-user-pen"></i> Düzenle: <%= u.username %></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="id" value="<%= u.id %>">
                <div class="mb-3">
                    <label>Lummy ID</label>
                    <input type="number" name="lummy_id" class="form-control" value="<%= u.lummy_id %>" required>
                </div>
                <div class="mb-3">
                    <label>Coin Bakiyesi</label>
                    <input type="number" name="coin_balance" class="form-control" value="<%= u.coin_balance %>" required>
                </div>
                <div class="mb-3">
                    <label>Seviye (Level)</label>
                    <input type="number" name="level" class="form-control" value="<%= u.level %>" required>
                </div>
                <div class="mb-3">
                    <label>Yetki (Role)</label>
                    <select name="role" class="form-select">
                        <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>Normal Üye</option>
                        <option value="moderator" <%= u.role === 'moderator' ? 'selected' : '' %>>Moderatör</option>
                        <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                        <option value="superadmin" <%= u.role === 'superadmin' ? 'selected' : '' %>>Süper Admin</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save"></i> Kaydet</button>
            </div>
        </form>
    </div>
</div>
<% }); %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>