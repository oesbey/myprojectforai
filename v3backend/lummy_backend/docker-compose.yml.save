version: '3.8'

services:
  # 1. KİRACI: ÇELİK KASA (POSTGRESQL)
  postgres:
    image: postgres:15-alpine
    container_name: yummy_db
    restart: always
    environment:
      POSTGRES_USER: yummy_admin
      POSTGRES_PASSWORD: YummySuperSecretPassword123!
      POSTGRES_DB: yummy_database
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data

  # 2. KİRACI: HIZLI BELLEK (REDIS)
  redis:
    image: redis:7-alpine
    container_name: yummy_redis
    restart: always
    ports:
      - "6379:6379"

volumes:
  pgdata:
